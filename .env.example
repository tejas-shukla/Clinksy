# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site URL — used to build canonical / OpenGraph / sitemap URLs.
# In production set this to your live domain, e.g. https://clinksy.com
NEXT_PUBLIC_SITE_URL=http://localhost:4001

# Optional: Resend API key for sending newsletter / welcome emails.
# Without this, signups are logged to the server console instead of emailed.
# Get one at https://resend.com
RESEND_API_KEY=
